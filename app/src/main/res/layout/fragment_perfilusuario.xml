<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <ImageView
            android:id="@+id/imgPerfilUsuario"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center"
            android:src="@drawable/perfilusuario"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/btnCambiarFoto"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:text="📷"
            android:layout_gravity="center" />

        <EditText
            android:id="@+id/txtFotoUrlPerfil"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Ingrese URL de imagen"
            android:visibility="gone"
            android:inputType="textUri"
            android:layout_marginBottom="22dp" />

        <EditText
            android:id="@+id/txtNombrePerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Nombre"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="40"
            android:textColor="#000000"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <EditText
            android:id="@+id/txtApellidoPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Apellido"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="40"
            android:textColor="#000000"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <EditText
            android:id="@+id/txtNicknamePerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="NickName"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="40"
            android:textColor="#000000"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <EditText
            android:id="@+id/txtCorreoPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Correo"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="40"
            android:textColor="#000000"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <EditText
            android:id="@+id/txtTelefonoPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Teléfono"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="9"
            android:textColor="#000000"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <EditText
            android:id="@+id/txtPasswordPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Nueva contraseña"
            android:inputType="textPassword"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:maxLength="40"
            android:textColor="#000000"
            android:drawableStart="@android:drawable/ic_lock_lock"
            android:drawableEnd="@android:drawable/ic_menu_edit" />

        <Button
            android:id="@+id/btnGuardarPerfil"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Guardar Cambios"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>