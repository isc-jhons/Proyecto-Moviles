<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#333333">

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="55dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="☰"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Conecta Maestro"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Space
                android:layout_width="55dp"
                android:layout_height="match_parent" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/contenedorFragments"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuLateral"
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <ImageView
                android:id="@+id/imgLogoMenu"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:src="@drawable/logo"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/txtNombreEmpresaMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Conecta Maestro"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingTop="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnInicio"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Inicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#1976D2" />

        <TextView
            android:id="@+id/btnBusquedaServicio"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Búsqueda Servicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#2196F3" />

        <TextView
            android:id="@+id/btnAdministrar"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Administrar"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:background="#D32F2F"
            android:visibility="gone" />
        <View
            android:id="@+id/lineaUsuario"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#BDBDBD"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnRegistrarServicio"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Registrar Negocio / Servicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#43A047"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnMiNegocio"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Mi Negocio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#62BC66"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnMiServicio"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Mi Servicio"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#62BC66"
            android:visibility="gone" />

        <View
            android:id="@+id/lineaUsuario2"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#BDBDBD"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnComentarios"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Comentarios"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:background="#7E57C2"
            android:visibility="gone" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnIniciarSesion"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Iniciar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#F57C00" />

        <TextView
            android:id="@+id/btnMiPerfil"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Mi Perfil"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#00897B"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Cerrar Sesión"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#D32F2F"
            android:visibility="gone" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>