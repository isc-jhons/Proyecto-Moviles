<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/imgPerfilBanner"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtPerfilNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textStyle="bold"
                android:textColor="#000000"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/txtPerfilCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textColor="#555555"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <RatingBar
                    android:id="@+id/ratingPerfil"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    android:isIndicator="false"
                    android:progressTint="#FBC02D"
                    android:secondaryProgressTint="#FBC02D"
                    android:progressBackgroundTint="#DDDDDD" />

                <TextView
                    android:id="@+id/txtPromedioPerfil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0.0"
                    android:textColor="#FBC02D"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtPerfilPersonas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 personas"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtPerfilEstado"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:text="Abierto"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#43A047" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabDescripcionPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Descripción General"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/tabComentariosPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Comentarios"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tabProyectosPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Publicaciones"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollDescripcionPerfil"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutDescripcionPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/des_perfil" />

                <TextView
                    android:id="@+id/txtPerfilDescripcion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Descripción:\n---"
                    android:textSize="13sp"
                    android:textColor="#000000" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/imgPerfilReferencia"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/refer_perfil" />

                <TextView
                    android:id="@+id/txtPerfilReferencia"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Referencia:\n---"
                    android:textSize="13sp"
                    android:textColor="#000000" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/direc_perfil" />

                <TextView
                    android:id="@+id/txtPerfilDireccion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Dirección:\n---"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnPerfilIr"
                    android:layout_width="70dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"
                    android:text="Ir"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:backgroundTint="#F57C00" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/tel_perfil" />

                <TextView
                    android:id="@+id/txtPerfilTelefono"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Teléfono / Fijo:\n---"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnPerfilLlamar"
                    android:layout_width="100dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"
                    android:text="Llamar"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:backgroundTint="#1565C0" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/wsp_perfil" />

                <TextView
                    android:id="@+id/txtPerfilWhatsapp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Número:\n---"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnPerfilMensaje"
                    android:layout_width="110dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"
                    android:text="Mensaje"
                    android:textColor="#FFFFFF"
                    android:textAllCaps="false"
                    android:backgroundTint="#43A047" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="8dp"
                android:paddingBottom="2dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/hora_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtPerfilHorarioTitulo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario atención"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <LinearLayout
                        android:id="@+id/layoutHorariosPerfil"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutComentariosPerfil"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="10dp">

        <ScrollView
            android:id="@+id/scrollComentariosPerfil"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/listaComentariosPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <TextView
            android:id="@+id/txtLoginComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Inicia sesión para comentar"
            android:textColor="#777777"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="12dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/layoutEscribirComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="14dp"
            android:paddingBottom="8dp"
            android:background="#FFFFFF">

            <ImageView
                android:id="@+id/imgUsuarioComentario"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/perfilusuario"
                android:scaleType="centerCrop" />

            <EditText
                android:id="@+id/txtNuevoComentario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="45dp"
                android:layout_weight="1"
                android:hint="Escribe un comentario..."
                android:layout_marginStart="8dp"
                android:background="@android:drawable/edit_text"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textSize="13sp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:maxLines="4"/>

            <Button
                android:id="@+id/btnPublicarComentario"
                android:layout_width="110dp"
                android:textSize="14sp"
                android:layout_height="48dp"
                android:text="Publicar"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutProyectosPerfil"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/scrollPublicacionesPerfil"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/listaPublicacionesPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>