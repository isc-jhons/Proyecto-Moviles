<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/imgEditarBanner"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery" />

    <Button
        android:id="@+id/btnEditarFoto"
        android:layout_width="65dp"
        android:layout_height="50dp"
        android:text="📷"
        android:textSize="22sp"
        android:layout_gravity="end"
        android:layout_marginTop="-55dp"
        android:layout_marginEnd="14dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

    <EditText
        android:id="@+id/txtEditarImagenUrl"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:hint="Ingrese URL de imagen"
        android:visibility="gone"
        android:inputType="textUri"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/edit_text" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <EditText
                android:id="@+id/txtEditarNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textStyle="bold"
                android:layout_marginTop="5dp"
                android:textColor="#000000"
                android:textSize="16sp"
                android:background="@android:color/transparent"
                android:drawableEnd="@android:drawable/ic_menu_edit"
                android:focusable="false"
                android:focusableInTouchMode="false" />

            <TextView
                android:id="@+id/txtEditarCategoria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textColor="#555555"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <RatingBar
                    android:id="@+id/ratingEditar"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    android:isIndicator="true"
                    android:progressTint="#FBC02D"
                    android:secondaryProgressTint="#FBC02D"
                    android:progressBackgroundTint="#DDDDDD" />

                <TextView
                    android:id="@+id/txtEditarPromedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="0.0"
                    android:textColor="#FBC02D"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtEditarPersonas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 personas"
                android:textColor="#000000"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtEditarEstado"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:layout_marginTop="7dp"
            android:text="Cerrado"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:background="#D50000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabEditarDescripcion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Descripción General"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000"
            android:background="#EEEEEE" />

        <TextView
            android:id="@+id/tabEditarComentarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Comentarios"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tabEditarProyectos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Publicaciones"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#000000" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollEditarDescripcion"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutEditarDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:id="@+id/layoutEditarRuc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RUC"
                    android:textColor="#000000"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/txtEditarRuc"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:inputType="number"
                    android:textSize="13sp"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:drawableEnd="@android:drawable/ic_menu_edit"
                    android:background="@android:drawable/edit_text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEditarDni"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DNI / CE"
                    android:textColor="#000000"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/txtEditarDni"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:textSize="13sp"
                    android:inputType="number"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:drawableEnd="@android:drawable/ic_menu_edit"
                    android:background="@android:drawable/edit_text" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="70dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/des_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción:"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <EditText
                        android:id="@+id/txtEditarDescripcion"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:hint="Descripción"
                        android:gravity="top"
                        android:textSize="13sp"
                        android:textColor="#000000"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:drawableEnd="@android:drawable/ic_menu_edit"
                        android:background="@android:drawable/edit_text" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:id="@+id/layoutEditarReferencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="top"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/refer_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Referencia:"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <EditText
                        android:id="@+id/txtEditarReferencia"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Referencia"
                        android:textSize="13sp"
                        android:textColor="#000000"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:drawableEnd="@android:drawable/ic_menu_edit"
                        android:background="@android:drawable/edit_text" />

                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEditarEspecialidades"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/espec_perfil" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Especialidades"
                        android:textColor="#000000"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <Spinner
                        android:id="@+id/spinnerEditarEspecialidad"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.3" />

                    <EditText
                        android:id="@+id/txtEditarTiempoExperiencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="0.7"
                        android:hint="N°"
                        android:gravity="center"
                        android:inputType="number"
                        android:background="@android:drawable/edit_text" />

                    <Spinner
                        android:id="@+id/spinnerEditarTipoExperiencia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btnEditarAgregarEspecialidad"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/listaEditarEspecialidades"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/direc_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dirección:"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <EditText
                        android:id="@+id/txtEditarDireccion"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:hint="Coordenadas GPS"
                        android:textColor="#000000"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:drawableEnd="@android:drawable/ic_dialog_map"
                        android:background="@android:drawable/edit_text" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/tel_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Teléfono / Fijo:"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <EditText
                        android:id="@+id/txtEditarTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:textSize="13sp"
                        android:hint="Teléfono / Fijo"
                        android:inputType="phone"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:drawableEnd="@android:drawable/ic_menu_edit"
                        android:background="@android:drawable/edit_text" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="58dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/wsp_perfil" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Número de WhatsApp:"
                        android:textSize="13sp"
                        android:textColor="#000000" />

                    <EditText
                        android:id="@+id/txtEditarWhatsapp"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:textSize="13sp"
                        android:hint="Número WhatsApp"
                        android:inputType="phone"
                        android:textColor="#000000"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:drawableEnd="@android:drawable/ic_menu_edit"
                        android:background="@android:drawable/edit_text" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#999999" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:src="@drawable/hora_perfil" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Horario atención"
                        android:textSize="13sp"
                        android:textColor="#000000" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">

                    <Spinner
                        android:id="@+id/spinnerEditarDia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <Spinner
                        android:id="@+id/spinnerEditarHoraInicio"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <Spinner
                        android:id="@+id/spinnerEditarHoraFin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btnEditarAgregarHorario"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="#000000" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/listaEditarHorarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnGuardarEditar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar Cambios"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:layout_marginTop="18dp" />

            <Button
                android:id="@+id/btnEliminarEditar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Eliminar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#D32F2F"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutEditarComentarios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="10dp">

        <ScrollView
            android:id="@+id/scrollEditarComentarios"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/listaEditarComentarios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layoutEditarProyectos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="#FFFFFF">

        <ScrollView
            android:id="@+id/scrollEditarPublicaciones"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp">

            <LinearLayout
                android:id="@+id/listaEditarPublicaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtSinPublicaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no hay publicaciones"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <ImageButton
            android:id="@+id/btnAgregarPublicacion"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="40dp"
            android:layout_marginBottom="18dp"
            android:src="@drawable/agregar_prub"
            android:background="@android:color/transparent"
            android:scaleType="centerInside"
            android:padding="8dp" />

    </FrameLayout>

</LinearLayout>